#include <iostream>

class DynamicBuffer {
private:
    int* arr;
    int size;

public:
    DynamicBuffer(int s) {
        size = s;
        arr = new int[size];
    }

    ~DynamicBuffer() {
        delete[] arr;
    }

    void fillArray() {
        for (int i = 0; i < size; i++) {
            arr[i] = i * 10;
        }
    }

    void printArray() {
        for (int i = 0; i < size; i++) {
            std::cout << arr[i] << " ";
        }
        std::cout << std::endl;
    }
};

int main() {
    DynamicBuffer buffer(5);
    buffer.fillArray();
    buffer.printArray();

    return 0;
}
